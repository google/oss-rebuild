FROM golang:1.25-alpine AS binary
ARG DEBUG=false
ARG BUILD_REPO
ARG BUILD_VERSION
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 go build \
    -ldflags="$([ ${DEBUG} = "true" ] || printf '-s -w') -X main.BuildRepo=${BUILD_REPO} -X main.BuildVersion=${BUILD_VERSION}" \
    -gcflags="-l=4" \
    ./cmd/rebuild-job
FROM alpine
COPY --from=binary /src/rebuild-job /
ENTRYPOINT ["/rebuild-job"]
